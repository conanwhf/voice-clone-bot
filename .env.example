# VoiceCloneBot runtime config

# Backend listen address
TTS_SERVER_HOST=127.0.0.1
TTS_SERVER_PORT=8000

# Request timeout strategy (seconds)
# Final timeout = min(
#   TTS_REQUEST_TIMEOUT
#   + max(0, text_len-120) * TTS_REQUEST_TIMEOUT_PER_CHAR
#   + estimated_chunks * TTS_REQUEST_TIMEOUT_PER_CHUNK,
#   TTS_REQUEST_TIMEOUT_MAX
# )
TTS_REQUEST_TIMEOUT=300
TTS_REQUEST_TIMEOUT_PER_CHAR=0.8
TTS_REQUEST_TIMEOUT_PER_CHUNK=90
TTS_REQUEST_TIMEOUT_MAX=7200

# Optional backend selection
# TTS_BACKEND=f5
